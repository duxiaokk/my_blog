# =========================
# 1. Python 编译缓存 (必加)
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so
.ruff_cache/
.pytest_cache/
.uv-cache/
.uv-python/
.venv_broken_*/
.venv_uv/

# =========================
# 2. 虚拟环境与依赖 (必加)
# =========================
venv/
.venv/
env/
.env  # ⚠️ 极其重要！绝对不能把包含真实密钥的 .env 传到仓库里

# =========================
# 3. 数据库文件 (根据情况)
# =========================
# 通常本地测试用的 SQLite 数据库不需要上传
blog.db
*.sqlite3

# =========================
# 4. IDE 与编辑器配置文件
# =========================
.vscode/
.idea/
*.swp
*.swo
.tmp/
.tmp_dbinspect/
.npm-cache/
.uv-cache-local/
pytest-cache-files-*/

# =========================
# 5. Codex / AI 辅助工具产生的垃圾文件 (针对你的项目)
# =========================
*.bak_codex
*.codex.tmp
*.copytest
Untitled*.jsonc
_codex_write_test.txt
_copy_source.txt
_replace_source.txt
_write_probe.txt

# =========================
# 6. 用户上传的静态资源 (可选)
# =========================
# 如果你不希望把本地测试时随意上传的头像和文章封面也存进 Git
image/avatars/*
!image/avatars/.gitkeep  # 保留目录结构，但不保留内容
